# ===== VLM 配置（文档解析与问答） =====
# 必填：DashScope API Key（当 MODEL_PROVIDER=dashscope 时）
DASHSCOPE_API_KEY=sk-你的真实密钥

# VLM 服务选择：dashscope | cliproxyapi | ollama
# - dashscope: 阿里云 DashScope qwen-vl 系列（需 API Key + 付费）
# - cliproxyapi: 通过 CLIProxyAPI 代理调用
# - ollama: 本地 Ollama 视觉模型（免费，需先安装 Ollama 并拉取模型）
MODEL_PROVIDER=dashscope

# DashScope VLM 模型名
VL_MODEL=qwen3-vl-8b-instruct

# ===== Ollama 本地 VLM 配置（当 MODEL_PROVIDER=ollama 时） =====
# 前提：安装 Ollama (brew install ollama) 并拉取视觉模型
# 推荐模型（从上到下效果递减 / 速度递增）：
#   ollama pull minicpm-v:8b    # ~5.5GB, 中英双语，文档理解效果最好
#   ollama pull qwen2.5vl:7b    # ~5.5GB, 阿里通义视觉，中文友好
#   ollama pull llama3.2-vision:11b  # ~8GB, Meta最新视觉模型
#   ollama pull llava:13b       # ~8GB, 经典多模态模型
# OLLAMA_API_BASE_URL=http://localhost:11434/v1
# OLLAMA_VL_MODEL=minicpm-v:8b

# ===== Embedding 配置（向量化） =====
# Embedding 服务选择：dashscope | local
# - dashscope: 使用 DashScope text-embedding-v3，需联网和 API 费用
# - local: 使用本地 sentence-transformers 模型，免费离线
EMBEDDING_PROVIDER=dashscope

# Embedding 模型名
# - dashscope 模式默认: text-embedding-v3
# - local 模式默认: BAAI/bge-small-zh-v1.5（首次自动下载约 90MB）
#   可选: BAAI/bge-base-zh-v1.5, BAAI/bge-large-zh-v1.5
EMBEDDING_MODEL=text-embedding-v3

# ===== CLIProxyAPI 配置（当 MODEL_PROVIDER=cliproxyapi 时） =====
# CLIPROXY_API_BASE_URL=http://127.0.0.1:8317
# CLIPROXY_API_KEY=sk-dummy
# CLIPROXY_PROVIDER=qclaw
# CLIPROXY_VL_MODEL=modelroute

# ===== 路径配置（一般不需要改） =====
# DOC_ROOT=doc
# OUTPUT_ROOT=outputs
